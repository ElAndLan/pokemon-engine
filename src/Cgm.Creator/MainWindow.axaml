<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cgm.Creator.MainWindow"
        Title="Creature Game Maker"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500">

  <!-- Phase 1 shell only: left nav placeholder, central tab area, bottom status bar.
       No functionality wired yet (see docs/IMPLEMENTATION_PLAN.md Phase 3). -->
  <DockPanel>

    <Border DockPanel.Dock="Bottom" Background="#1B222B" Height="26">
      <TextBlock Text="Ready" Foreground="#C8D0D8"
                 VerticalAlignment="Center" Margin="10,0" FontSize="12" />
    </Border>

    <Border DockPanel.Dock="Left" Background="#161B22" Width="240"
            BorderBrush="#0D1116" BorderThickness="0,0,1,0">
      <StackPanel Margin="12">
        <TextBlock Text="PROJECT" Foreground="#5A6672" FontSize="11" FontWeight="SemiBold" />
        <TextBlock Text="No project open" Foreground="#8892A0" Margin="0,8,0,0" FontSize="13" />
      </StackPanel>
    </Border>

    <TabControl Margin="4">
      <TabItem Header="Welcome">
        <StackPanel Margin="24" Spacing="8">
          <TextBlock Text="Creature Game Maker" FontSize="22" FontWeight="Bold" />
          <TextBlock Text="Creator shell — Phase 1 scaffold."
                     Foreground="#A0A8B0" FontSize="14" />
        </StackPanel>
      </TabItem>
    </TabControl>

  </DockPanel>
</Window>
