<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cgm.Creator.ViewModels"
             x:Class="Cgm.Creator.Views.SoundView"
             x:DataType="vm:SoundDocument">
  <StackPanel Margin="16" Spacing="10" MaxWidth="420" HorizontalAlignment="Left">
    <TextBlock Text="{Binding AssetPath}" Opacity="0.7" FontSize="12" />
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Name" Width="70" VerticalAlignment="Center" />
      <TextBox Text="{Binding Name}" Width="220" />
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Kind" Width="70" VerticalAlignment="Center" />
      <ComboBox ItemsSource="{Binding Kinds}" SelectedItem="{Binding Kind}" Width="140" />
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Loop" Width="70" VerticalAlignment="Center" />
      <CheckBox IsChecked="{Binding Loop}" />
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Volume" Width="70" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding Volume}" Minimum="0" Maximum="100" Increment="5" Width="130" FormatString="0" />
    </StackPanel>
    <TextBlock Text="Audition plays through the Runtime (F5 playtest); the Creator plays no audio."
               Opacity="0.6" FontSize="11" TextWrapping="Wrap" />
  </StackPanel>
</UserControl>
