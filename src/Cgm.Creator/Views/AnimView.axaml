<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cgm.Creator.ViewModels"
             xmlns:model="using:Cgm.Core.Model"
             x:Class="Cgm.Creator.Views.AnimView"
             x:DataType="vm:AnimDocument">
  <DockPanel Margin="16">

    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <TextBlock Text="Name" VerticalAlignment="Center" />
      <TextBox Text="{Binding Name}" Width="200" />
      <CheckBox Content="Loop" IsChecked="{Binding Loop}" Margin="12,0,0,0" />
    </StackPanel>

    <!-- Fixed-tick preview: driven by the authored per-frame durations. -->
    <Border DockPanel.Dock="Right" Width="180" Margin="12,0,0,0">
      <StackPanel Spacing="8">
        <TextBlock Text="Preview" FontWeight="SemiBold" />
        <Border Width="128" Height="128" Background="#20000000" HorizontalAlignment="Left">
          <Image x:Name="PreviewImage" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ToggleButton x:Name="PlayToggle" Content="Play" IsCheckedChanged="OnPlayToggled" />
        <TextBlock x:Name="PreviewLabel" Opacity="0.6" FontSize="11" />
      </StackPanel>
    </Border>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
      <Button Content="▲" Click="OnMoveUp" />
      <Button Content="▼" Click="OnMoveDown" />
      <Button Content="Remove" Click="OnRemove" />
      <TextBlock Text="ms" VerticalAlignment="Center" Margin="12,0,0,0" />
      <NumericUpDown x:Name="MsBox" Minimum="1" Increment="25" Width="120" FormatString="0" Value="150" />
      <Button Content="Set" Click="OnSetMs" />
    </StackPanel>

    <ListBox x:Name="FrameList" ItemsSource="{Binding Frames}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="model:AnimFrame">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding Sprite}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Ms, StringFormat={}{0} ms}" Opacity="0.6" VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </DockPanel>
</UserControl>
