<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cgm.Creator.ViewModels"
             x:Class="Cgm.Creator.Views.MapView"
             x:DataType="vm:MapDocument">
  <DockPanel Margin="8">

    <!-- Toolbar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
      <ComboBox x:Name="ToolBox" SelectionChanged="OnToolChanged" Width="120" />
      <ComboBox x:Name="LayerBox" SelectionChanged="OnLayerChanged" Width="130" />
      <ComboBox x:Name="ModeBox" SelectionChanged="OnModeChanged" Width="120" />
      <Separator Width="8" />
      <TextBlock Text="Zoom" VerticalAlignment="Center" />
      <Slider x:Name="ZoomSlider" Minimum="0.25" Maximum="8" Value="1" TickFrequency="0.25"
              Width="110" ValueChanged="OnZoomChanged" />
      <TextBlock x:Name="ZoomLabel" Width="44" VerticalAlignment="Center" />
      <Separator Width="8" />
      <CheckBox x:Name="CollisionToggle" Content="Show collision" IsCheckedChanged="OnOverlayToggled" />
      <CheckBox x:Name="EncounterToggle" Content="Show encounters" IsCheckedChanged="OnOverlayToggled" />
    </StackPanel>

    <!-- Entity placement -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
      <TextBlock Text="Collision value" VerticalAlignment="Center" />
      <ComboBox x:Name="CollisionValueBox" Width="130" SelectionChanged="OnCollisionValueChanged" />
      <Button Content="Pick encounter table…" Click="OnPickEncounter" />
      <TextBlock x:Name="EncounterLabel" VerticalAlignment="Center" Opacity="0.7" />
      <Separator Width="8" />
      <TextBlock Text="Entity kind" VerticalAlignment="Center" />
      <ComboBox x:Name="EntityKindBox" Width="130" />
      <Button Content="Delete selected" Click="OnDeleteEntity" />
      <Button Content="Configure…" Click="OnConfigureEntity" />
      <TextBlock x:Name="EntityLabel" VerticalAlignment="Center" Opacity="0.7" />
    </StackPanel>

    <!-- Layer visibility + tilesets -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
      <CheckBox x:Name="ShowGround" Content="Ground" IsChecked="True" IsCheckedChanged="OnRedraw" />
      <CheckBox x:Name="ShowBelow" Content="Deco below" IsChecked="True" IsCheckedChanged="OnRedraw" />
      <CheckBox x:Name="ShowAbove" Content="Deco above" IsChecked="True" IsCheckedChanged="OnRedraw" />
      <CheckBox x:Name="GridToggle" Content="Grid" IsChecked="True" IsCheckedChanged="OnRedraw" />
      <CheckBox x:Name="LockGround" Content="Lock G" />
      <CheckBox x:Name="LockBelow" Content="Lock B" />
      <CheckBox x:Name="LockAbove" Content="Lock A" />
      <Rectangle Width="1" Fill="#33445A" Margin="4,2" />
      <Button Content="＋ Add tileset" Click="OnAddTileset"
              ToolTip.Tip="Choose a tileset whose tiles fill the palette on the right" />
      <TextBlock x:Name="TilesetLabel" VerticalAlignment="Center" Opacity="0.7" />
      <TextBlock x:Name="CursorLabel" VerticalAlignment="Center" Opacity="0.7" />
    </StackPanel>

    <!-- Palette -->
    <Border DockPanel.Dock="Right" Width="180" Margin="8,0,0,0">
      <Grid>
        <ScrollViewer>
          <WrapPanel x:Name="Palette" />
        </ScrollViewer>
        <TextBlock x:Name="EmptyPaletteHint" IsVisible="False" TextWrapping="Wrap"
                   VerticalAlignment="Top" Foreground="#8A97A6" TextAlignment="Center" Margin="6,20"
                   Text="No tiles yet.&#10;Click ＋ Add tileset to pick one, then click a tile here to paint with it." />
      </Grid>
    </Border>

    <!-- Canvas -->
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
      <LayoutTransformControl x:Name="ZoomHost">
        <Image x:Name="MapImage" Stretch="None"
               PointerPressed="OnCanvasPressed" PointerMoved="OnCanvasMoved" PointerReleased="OnCanvasReleased"
               PointerCaptureLost="OnCanvasCaptureLost" />
      </LayoutTransformControl>
    </ScrollViewer>

  </DockPanel>
</UserControl>
