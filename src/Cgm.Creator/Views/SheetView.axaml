<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cgm.Creator.ViewModels"
             x:Class="Cgm.Creator.Views.SheetView"
             x:DataType="vm:SheetDocument">
  <DockPanel Margin="8">

    <!-- Toolbar: slicing layers + zoom -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="Fit gutters" Click="OnApplyGutter" IsEnabled="{Binding HasGutterSuggestion}"
              ToolTip.Tip="Slice by the detected transparent-gutter grid" />
      <Button Content="Fit common size" Click="OnApplySize" IsEnabled="{Binding HasSizeSuggestion}"
              ToolTip.Tip="Slice by the largest common cell size" />
      <Button Content="Detect sprites" Click="OnApplyComponents" IsEnabled="{Binding HasPixels}"
              ToolTip.Tip="Find sprite bounds by connected pixels (irregular sheets)" />
      <Separator Width="16" />
      <TextBlock Text="Zoom" VerticalAlignment="Center" />
      <Slider x:Name="ZoomSlider" Minimum="0.1" Maximum="8" Value="2" Width="140" ValueChanged="OnZoomChanged" />
      <TextBlock x:Name="ZoomLabel" VerticalAlignment="Center" Width="44" />
      <Button Content="Fit" Click="OnFit" ToolTip.Tip="Zoom to fit the whole sheet" />
      <Button Content="1:1" Click="OnActualSize" ToolTip.Tip="Actual pixel size" />
    </StackPanel>

    <Border DockPanel.Dock="Top" Background="#5A3B18" Padding="8" Margin="0,0,0,8"
            IsVisible="{Binding HasDimensionMismatch}">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock VerticalAlignment="Center"
                   Text="The PNG dimensions differ from the saved sheet metadata, so the grid cannot cover the full image." />
        <Button Content="Use actual size and re-slice" Click="OnRepairDimensions" />
      </StackPanel>
    </Border>

    <!-- Grid parameters + sheet info -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
      <TextBlock Text="Cell" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding CellW}" Minimum="1" Increment="1" Width="96" FormatString="0" />
      <NumericUpDown Value="{Binding CellH}" Minimum="1" Increment="1" Width="96" FormatString="0" />
      <TextBlock Text="Offset" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding OffsetX}" Minimum="0" Increment="1" Width="96" FormatString="0" />
      <NumericUpDown Value="{Binding OffsetY}" Minimum="0" Increment="1" Width="96" FormatString="0" />
      <TextBlock Text="Spacing" VerticalAlignment="Center" />
      <NumericUpDown Value="{Binding SpacingX}" Minimum="0" Increment="1" Width="96" FormatString="0" />
      <NumericUpDown Value="{Binding SpacingY}" Minimum="0" Increment="1" Width="96" FormatString="0" />
      <Rectangle Width="1" Fill="#33445A" Margin="6,2" />
      <TextBlock x:Name="InfoLabel" VerticalAlignment="Center" Opacity="0.7" />
    </StackPanel>

    <!-- Cell list + per-cell actions -->
    <Border DockPanel.Dock="Right" Width="270" Margin="8,0,0,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
          <TextBox x:Name="RenameBox" PlaceholderText="name_{n}" Width="160" />
          <Button Content="Rename all" Click="OnRenameAll" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,6,0,0">
          <Button Content="Create Tileset from this Sheet" Click="OnCreateTileset"
                  HorizontalAlignment="Stretch"
                  ToolTip.Tip="Use the current accepted cells as a paintable map tileset" />
          <Button Content="Exclude selected" Click="OnRemoveSelected" HorizontalAlignment="Stretch" />
          <Button Content="Create animation from selection" Click="OnCreateAnimation" HorizontalAlignment="Stretch" />
          <Button Content="Create walk clips (12-cell sheet)" Click="OnCreateWalkClips" HorizontalAlignment="Stretch" />
        </StackPanel>
        <ListBox x:Name="CellList" ItemsSource="{Binding CellViews}" SelectionMode="Multiple"
                 SelectionChanged="OnListSelectionChanged">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <VirtualizingStackPanel />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:SheetCellView">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding SpriteId.Slug}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Size}" Opacity="0.5" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Canvas: the sheet composited with its cell overlay, at any zoom -->
    <Border Background="#0C0F13">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                    x:Name="CanvasScroll">
        <LayoutTransformControl x:Name="ZoomHost">
          <Panel x:Name="CanvasPanel" Background="Transparent"
                 PointerPressed="OnCanvasPressed" PointerMoved="OnCanvasMoved" PointerReleased="OnCanvasReleased">
            <Image x:Name="SheetImage" Stretch="None" />
            <Canvas>
              <Border x:Name="RubberBand" BorderBrush="#F0F0F040" BorderThickness="1"
                      Background="#40F0F040" IsVisible="False" />
            </Canvas>
          </Panel>
        </LayoutTransformControl>
      </ScrollViewer>
    </Border>

  </DockPanel>
</UserControl>
