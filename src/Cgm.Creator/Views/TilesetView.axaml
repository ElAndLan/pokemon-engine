<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cgm.Creator.ViewModels"
             x:Class="Cgm.Creator.Views.TilesetView"
             x:DataType="vm:TilesetDocument">
  <DockPanel Margin="8">

    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <TextBlock Text="Name" VerticalAlignment="Center" />
      <TextBox Text="{Binding Name}" Width="200" />
      <Button Content="Add tile" Click="OnAddTile" />
      <Button Content="Remove last" Click="OnRemoveLast" />
      <Button Content="Clear tile" Click="OnClearTile" />
    </StackPanel>

    <!-- Inspector for the selected tile -->
    <Border DockPanel.Dock="Right" Width="240" Margin="8,0,0,0">
      <StackPanel x:Name="Inspector" Spacing="8" IsEnabled="False">
        <TextBlock x:Name="TileHeader" FontWeight="SemiBold" Text="No tile selected" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Sprite" Width="60" VerticalAlignment="Center" />
          <Button x:Name="SpriteButton" Content="Pick…" Click="OnPickSprite" />
        </StackPanel>
        <TextBlock x:Name="SpriteLabel" Opacity="0.6" FontSize="11" TextWrapping="Wrap" />
        <CheckBox x:Name="SolidBox" Content="Solid" IsCheckedChanged="OnSolid" />
        <CheckBox x:Name="GrassBox" Content="Grass (encounters)" IsCheckedChanged="OnGrass" />
        <CheckBox x:Name="WaterBox" Content="Water" IsCheckedChanged="OnWater" />
        <CheckBox x:Name="CounterBox" Content="Counter" IsCheckedChanged="OnCounter" />
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Ledge" Width="60" VerticalAlignment="Center" />
          <ComboBox x:Name="LedgeBox" ItemsSource="{Binding LedgeDirs}" SelectionChanged="OnLedge" Width="120" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Terrain" Width="60" VerticalAlignment="Center" />
          <TextBox x:Name="TerrainBox" Width="130" LostFocus="OnTerrain" />
        </StackPanel>
      </StackPanel>
    </Border>

    <ScrollViewer>
      <WrapPanel x:Name="TileGrid" />
    </ScrollViewer>

  </DockPanel>
</UserControl>
