<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Cgm.Creator.ViewModels"
        x:Class="Cgm.Creator.Views.PickEntityWindow"
        x:DataType="vm:ReferencePickerViewModel"
        Title="Creature Game Maker"
        Width="460" Height="560" MinWidth="360" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        CanResize="True">
  <DockPanel Margin="16">
    <TextBlock x:Name="PromptText" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8" />
    <TextBox x:Name="SearchBox" DockPanel.Dock="Top" PlaceholderText="Search by name or slug…"
             Text="{Binding SearchText, Mode=TwoWay}" Margin="0,0,0,8" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button Content="Cancel" Click="OnCancel" MinWidth="80" />
      <Button x:Name="OkButton" Content="OK" Click="OnOk" IsDefault="True" MinWidth="80" />
    </StackPanel>
    <ListBox x:Name="ChoiceList" ItemsSource="{Binding Choices}" SelectedItem="{Binding Selected, Mode=TwoWay}"
             DoubleTapped="OnOk">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:ReferenceChoice">
          <TextBlock Text="{Binding Display}" VerticalAlignment="Center" />
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </DockPanel>
</Window>
